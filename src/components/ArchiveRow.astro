---
import type { CollectionEntry } from "astro:content";
import TagPill from "./TagPill.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const monthDayText = new Intl.DateTimeFormat("zh-CN", {
  month: "2-digit",
  day: "2-digit"
}).format(post.data.pubDate);
const yearText = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric"
}).format(post.data.pubDate);

const difficultyClassMap: Record<string, string> = {
  Easy: "difficulty-easy",
  Medium: "difficulty-medium",
  Hard: "difficulty-hard",
  Notes: "difficulty-notes"
};

const difficultyClass = difficultyClassMap[post.data.difficulty] ?? "difficulty-notes";
const contestLabel = post.data.contest || post.data.oj || "未命名比赛";
const kickerParts = [post.data.category, contestLabel, post.data.track].filter(Boolean);
---

<article class="archive-row">
  <div class="archive-date">
    <time datetime={post.data.pubDate.toISOString()}>{monthDayText}</time>
    <span>{yearText}</span>
  </div>

  <div class="archive-body">
    <p class="archive-kicker">{kickerParts.join(" / ")}</p>
    <div class="archive-title-line">
      <h3>
        <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
      </h3>
      {post.data.featured && <span class="entry-badge">收录</span>}
    </div>
    <p class="archive-summary">{post.data.description}</p>
    <div class="archive-meta">
      {post.data.track && <span>{post.data.track}</span>}
      <span class:list={["difficulty-pill", difficultyClass]}>{post.data.difficulty}</span>
      <span>{post.data.language}</span>
      <span>{post.data.tags.length} 个标签</span>
    </div>
    <div class="tag-row">
      {post.data.tags.slice(0, 4).map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
    </div>
  </div>
</article>
