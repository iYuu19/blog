---
import { getSiteSettings } from "../utils/site";

const year = new Date().getFullYear();
const site = await getSiteSettings();
const footerLinks = site.navLinks?.length
  ? site.navLinks
  : [
      { href: "/", label: "首页" },
      { href: "/contests", label: "比赛" },
      { href: "/categories", label: "分类" },
      { href: "/blog", label: "归档" },
      { href: "/tags", label: "标签" },
      { href: "/about", label: "关于" }
    ];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-brand-block">
      <p class="eyebrow">{site.brandMark}</p>
      <strong>{site.siteTitle}</strong>
      <p>{site.footerDescription}</p>
    </div>

    <nav class="footer-nav" aria-label="页脚导航">
      {footerLinks.map((link) => (
        <a class="footer-link-pill" href={link.href}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="footer-meta-card">
      {site.footerPanelEyebrow && <p class="footer-meta-kicker">{site.footerPanelEyebrow}</p>}
      <p class="footer-meta-title">{site.footerPanelTitle}</p>
      <p>{site.footerPanelText}</p>
      <p>© {year} {site.copyrightName}</p>
    </div>
  </div>
</footer>
