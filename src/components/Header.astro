---
import { getSiteSettings } from "../utils/site";

const path = Astro.url.pathname;
const site = await getSiteSettings();
const links = site.navLinks?.length
  ? site.navLinks
  : [
      { href: "/", label: "首页" },
      { href: "/contests", label: "比赛" },
      { href: "/categories", label: "分类" },
      { href: "/blog", label: "归档" },
      { href: "/tags", label: "标签" },
      { href: "/about", label: "关于" }
    ];

const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">{site.brandMark}</span>
      <span>
        <strong>{site.siteTitle}</strong>
        <small>{site.headerTagline}</small>
      </span>
    </a>
    <div class="nav-right">
      <nav class="nav-links" aria-label="主导航">
        {
          links.map((link) => (
            <a class:list={["nav-link", isActive(link.href) ? "is-active" : ""]} href={link.href}>
              {link.label}
            </a>
          ))
        }
      </nav>
      {
        site.headerCtaLabel && site.headerCtaHref && (
          <a class="nav-cta" href={site.headerCtaHref}>
            {site.headerCtaLabel}
          </a>
        )
      }
    </div>
  </div>
</header>
