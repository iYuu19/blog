---
interface TocNode {
  depth: number;
  slug: string;
  text: string;
  children: TocNode[];
}

interface Props {
  nodes: TocNode[];
  level?: number;
}

const { nodes, level = 0 } = Astro.props;
const isRootLevel = level === 0;
---

<ul class:list={[isRootLevel ? "article-index-list" : "article-index-sublist"]}>
  {
    nodes.map((node) => (
      <li
        class:list={["article-index-item", `article-index-depth-${node.depth}`]}
        data-depth={node.depth}
        data-toc-node={node.slug}
      >
        <a href={`#${node.slug}`} data-toc-link={node.slug} title={node.text}>
          <span>{node.text}</span>
        </a>

        {
          node.children.length > 0 && (
            <div class="article-index-branch" data-toc-branch={node.slug}>
              <Astro.self nodes={node.children} level={level + 1} />
            </div>
          )
        }
      </li>
    ))
  }
</ul>
