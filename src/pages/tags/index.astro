---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const tagsPage =
  (
    await getEntry("site-tags-page", "tags-page")
  )?.data ?? {
    pageTitle: "标签",
    pageDescription: "按标签浏览题解与总结。",
    heroEyebrow: "Tag Index",
    heroTitle: "标签",
    heroIntro: "按标签翻会比只看日期更方便，尤其是回顾某一类题的时候。",
    latestPrefix: "最新内容："
  };

const posts = await getCollection("blog", ({ data }) => !data.draft);

const tagMap = posts.reduce<Record<string, { count: number; latestTitle: string; latestDate: number }>>(
  (acc, post) => {
    for (const tag of post.data.tags) {
      const publishedAt = post.data.pubDate.valueOf();
      const previous = acc[tag];

      if (!previous || publishedAt > previous.latestDate) {
        acc[tag] = {
          count: (previous?.count ?? 0) + 1,
          latestTitle: post.data.title,
          latestDate: publishedAt
        };
      } else {
        previous.count += 1;
      }
    }

    return acc;
  },
  {}
);

const tags = Object.entries(tagMap)
  .map(([name, meta]) => ({ name, ...meta }))
  .sort((a, b) => b.count - a.count || b.latestDate - a.latestDate);
---

<Layout title={`${tagsPage.pageTitle} | iYuu Notes`} description={tagsPage.pageDescription}>
  <section class="shell page-intro fade-up">
    <p class="eyebrow">{tagsPage.heroEyebrow}</p>
    <h1>{tagsPage.heroTitle}</h1>
    <p>{tagsPage.heroIntro}</p>
  </section>

  <section class="shell tag-index-grid section-block">
    {tags.map((tag) => (
      <a class="tag-board" href={`/tags/${tag.name}/`}>
        <div class="tag-board-head">
          <span class="tag-board-name">#{tag.name}</span>
          <strong>{tag.count}</strong>
        </div>
        <p>{tagsPage.latestPrefix}{tag.latestTitle}</p>
      </a>
    ))}
  </section>
</Layout>
