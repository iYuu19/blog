---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
  getCategoryDefinitions,
  getTagDefinitions,
  slugifySegment
} from "../../utils/content";
import { getPageLayouts } from "../../utils/site";

const tagsPage =
  (
    await getEntry("site-tags-page", "tags-page")
  )?.data ?? {
    pageTitle: "标签",
    pageDescription: "按标签浏览题解与总结。",
    heroEyebrow: "Tag Index",
    heroTitle: "标签",
    heroIntro: "按标签回看内容，会比只按日期翻文章更方便，尤其适合回顾某个知识点。",
    latestPrefix: "最新内容："
  };
const pageLayouts = await getPageLayouts();

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tagDefinitions = await getTagDefinitions();
const categoryDefinitions = await getCategoryDefinitions();

const tagStats = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        count: number;
        latestTitle: string;
        latestDate: number;
      }
    >
  >((acc, post) => {
    for (const tag of post.data.tags) {
      const publishedAt = post.data.pubDate.valueOf();
      const previous = acc[tag];

      if (!previous || publishedAt > previous.latestDate) {
        acc[tag] = {
          name: tag,
          count: (previous?.count ?? 0) + 1,
          latestTitle: post.data.title,
          latestDate: publishedAt
        };
      } else {
        previous.count += 1;
      }
    }

    return acc;
  }, {})
);

const definitionMap = new Map(tagDefinitions.map((definition) => [definition.name, definition]));
const statsMap = new Map(tagStats.map((tag) => [tag.name, tag]));
const categoryMap = new Map(categoryDefinitions.map((category) => [category.name, category]));

const tags = [
  ...tagDefinitions.map((definition) => {
    const stats = statsMap.get(definition.name);
    const relatedCategory = definition.relatedCategory
      ? categoryMap.get(definition.relatedCategory)
      : undefined;

    return {
      name: definition.name,
      slug: definition.slug!,
      description: definition.description,
      learningFocus: definition.learningFocus,
      relatedCategory: definition.relatedCategory,
      relatedCategoryHref: relatedCategory
        ? `/categories/${relatedCategory.slug}/`
        : definition.relatedCategory
          ? `/categories/${slugifySegment(definition.relatedCategory)}/`
          : "",
      exampleTopics: definition.exampleTopics,
      sortOrder: definition.sortOrder,
      count: stats?.count ?? 0,
      latestTitle:
        stats?.latestTitle ?? "这个标签说明卡已经建好，后面可以继续往里补文章。",
      latestDate: stats?.latestDate ?? 0,
      latestDateText: stats
        ? new Intl.DateTimeFormat("zh-CN", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit"
          }).format(stats.latestDate)
        : "待补充",
      hasPosts: Boolean(stats)
    };
  }),
  ...tagStats
    .filter((tag) => !definitionMap.has(tag.name))
    .map((tag) => ({
      name: tag.name,
      slug: slugifySegment(tag.name),
      description:
        "这个标签已经在文章里出现了，但还没有在后台的“分类与标签”里补说明卡。",
      learningFocus: "可以去后台补一段说明，让这个标签在前台看起来更完整。",
      relatedCategory: "",
      relatedCategoryHref: "",
      exampleTopics: [],
      sortOrder: 999,
      count: tag.count,
      latestTitle: tag.latestTitle,
      latestDate: tag.latestDate,
      latestDateText: new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit"
      }).format(tag.latestDate),
      hasPosts: true
    }))
].sort(
  (a, b) =>
    a.sortOrder - b.sortOrder ||
    b.count - a.count ||
    b.latestDate - a.latestDate ||
    a.name.localeCompare(b.name, "zh-CN")
);

const tagsSections = (pageLayouts.tagsSections?.length ? pageLayouts.tagsSections : [])
  .filter((section) => section.enabled)
  .map((section, index) => ({
    ...section,
    title: section.title || "全部标签",
    note: section.note || `${tags.length} 个标签`,
    id: slugifySegment(section.anchor || `${section.type}-${index + 1}`)
  }));
---

<Layout title={`${tagsPage.pageTitle} | iYuu Notes`} description={tagsPage.pageDescription}>
  <section class="shell page-intro fade-up">
    <p class="eyebrow">{tagsPage.heroEyebrow}</p>
    <h1>{tagsPage.heroTitle}</h1>
    <p>{tagsPage.heroIntro}</p>
  </section>

  {tagsSections.map((section) => (
    <>
      {
        section.type === "tag-grid" && (
          <section class="shell section-block" id={section.id}>
            <div class="section-head">
              <h2>{section.title}</h2>
              {section.note && <span class="section-note">{section.note}</span>}
            </div>
            <div class="tag-index-grid">
              {tags.map((tag) => (
                <a class="tag-board category-board category-board-rich" href={`/tags/${tag.name}/`}>
                  <div class="tag-board-head">
                    <span class="tag-board-name">#{tag.name}</span>
                    <strong>{tag.count}</strong>
                  </div>
                  <p class="category-board-description">{tag.description}</p>
                  <p class="category-board-track">适合从这里看：{tag.learningFocus}</p>
                  <p>{tagsPage.latestPrefix}{tag.latestTitle}</p>
                  {tag.exampleTopics.length > 0 && (
                    <div class="category-example-row">
                      {tag.exampleTopics.slice(0, 3).map((topic) => (
                        <span class="tag-pill">{topic}</span>
                      ))}
                    </div>
                  )}
                  <div class="category-board-footer">
                    <span>{tag.hasPosts ? `最近更新：${tag.latestDateText}` : "准备中"}</span>
                    <div class="tag-row">
                      {tag.relatedCategory && (
                        <span class="tag-pill">关联分类：{tag.relatedCategory}</span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </>
  ))}
</Layout>
