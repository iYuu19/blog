---
import { getCollection, getEntry } from "astro:content";
import ArchiveRow from "../../components/ArchiveRow.astro";
import Layout from "../../layouts/Layout.astro";
import { getSiteSettings } from "../../utils/site";

const detailPages =
  (
    await getEntry("site-detail-pages", "detail-pages")
  )?.data ?? {
    tagPage: {
      pageEyebrow: "Tag View",
      pageDescriptionTemplate: "标签 {{tag}} 下的所有文章。",
      heroIntroTemplate: "这个标签下目前有 {{count}} 篇内容。"
    }
  };
const tagPage = detailPages.tagPage;
const site = await getSiteSettings();

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    }
  }));
}

const { tag, posts } = Astro.props;
const pageDescription = tagPage.pageDescriptionTemplate.replace("{{tag}}", tag);
const heroIntro = tagPage.heroIntroTemplate.replace("{{count}}", String(posts.length));
---

<Layout title={`${tag} | ${site.siteTitle}`} description={pageDescription}>
  <section class="shell page-intro fade-up">
    <p class="eyebrow">{tagPage.pageEyebrow}</p>
    <h1>#{tag}</h1>
    <p>{heroIntro}</p>
  </section>

  <section class="shell section-block">
    <div class="archive-list">
      {posts.map((post) => <ArchiveRow post={post} />)}
    </div>
  </section>
</Layout>
