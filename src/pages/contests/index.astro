---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getContestCover, getContestName, getContestSlug } from "../../utils/content";

const contestsPage =
  (
    await getEntry("site-contests-page", "contests-page")
  )?.data ?? {
    pageTitle: "比赛",
    pageDescription: "按比赛查看 iYuu 的 WP、复盘与题目记录。",
    heroEyebrow: "Contest Index",
    heroTitle: "比赛",
    heroIntro: "这里按比赛整理文章。以后一场比赛里的不同题目和复盘，都可以放到同一个比赛分类下面。",
    contestLabel: "比赛",
    countSuffix: "篇",
    tracksPrefix: "方向：",
    latestPrefix: "最新内容：",
    emptyTracksText: "待补充"
  };

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const contests = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
        latestTitle: string;
        latestDate: number;
        tracks: Set<string>;
        coverImage: string;
      }
    >
  >((acc, post) => {
    const name = getContestName(post);
    const slug = getContestSlug(post);
    const coverImage = getContestCover(post);
    const publishedAt = post.data.pubDate.valueOf();
    const previous = acc[slug];

    if (!previous || publishedAt > previous.latestDate) {
      acc[slug] = {
        name,
        slug,
        count: (previous?.count ?? 0) + 1,
        latestTitle: post.data.title,
        latestDate: publishedAt,
        tracks: new Set([post.data.track].filter(Boolean)),
        coverImage: coverImage || previous?.coverImage || ""
      };
    } else {
      previous.count += 1;
      if (post.data.track) {
        previous.tracks.add(post.data.track);
      }
      if (!previous.coverImage && coverImage) {
        previous.coverImage = coverImage;
      }
    }

    return acc;
  }, {})
)
  .map((contest) => ({ ...contest, tracks: [...contest.tracks] }))
  .sort((a, b) => b.latestDate - a.latestDate || b.count - a.count);
---

<Layout title={`${contestsPage.pageTitle} | iYuu Notes`} description={contestsPage.pageDescription}>
  <section class="shell page-intro">
    <p class="eyebrow">{contestsPage.heroEyebrow}</p>
    <h1>{contestsPage.heroTitle}</h1>
    <p>{contestsPage.heroIntro}</p>
  </section>

  <section class="shell contest-index-grid section-block">
    {contests.map((contest) => (
      <a
        class:list={["contest-board", contest.coverImage ? "has-cover" : ""]}
        href={`/contests/${contest.slug}/`}
        style={contest.coverImage ? `--contest-cover: url('${contest.coverImage}')` : undefined}
      >
        <div class="contest-board-content">
          <div class="contest-board-head">
            <strong>{contest.name}</strong>
            <span>{contest.count} {contestsPage.countSuffix}</span>
          </div>
          <p>{contestsPage.tracksPrefix}{contest.tracks.join(" / ") || contestsPage.emptyTracksText}</p>
          <p>{contestsPage.latestPrefix}{contest.latestTitle}</p>
        </div>
      </a>
    ))}
  </section>
</Layout>
