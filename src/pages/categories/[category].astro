---
import { getCollection, getEntry } from "astro:content";
import ArchiveRow from "../../components/ArchiveRow.astro";
import TagPill from "../../components/TagPill.astro";
import Layout from "../../layouts/Layout.astro";
import { getCategoryDefinitions, getCategoryName, getCategorySlug } from "../../utils/content";
import { getSiteSettings } from "../../utils/site";

const detailPages =
  (
    await getEntry("site-detail-pages", "detail-pages")
  )?.data ?? {
    categoryPage: {
      pageEyebrow: "Category View",
      pageDescriptionTemplate: "{{category}} 分类下的所有文章。",
      postsLabel: "文章数",
      contestsLabel: "比赛数",
      latestUpdateLabel: "最近更新",
      emptyLatestUpdateText: "待补充",
      overviewLabel: "这个栏目会看到什么",
      overviewBody: "这一页会把同一主题下的内容集中放在一起，方便按方向连续阅读，而不是零散地按时间翻找。",
      commonTagsLabel: "常见标签",
      commonTagsEmpty: "相关标签会随着内容更新逐步补齐",
      commonTracksLabel: "常见方向",
      commonTracksEmpty: "等文章继续补充之后会更清楚",
      topicsLabel: "这个栏目会涉及的话题",
      topicsEmpty: "相关话题会随着后续文章一起慢慢补充。",
      emptyFeed: "这个栏目已经先建好，相关内容会在后续更新中逐步补充进来。"
    }
  };
const categoryPage = detailPages.categoryPage;
const site = await getSiteSettings();

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const definitions = await getCategoryDefinitions();
  const categoryMap = new Map(
    definitions.map((definition) => [
      definition.slug!,
      { name: definition.name, slug: definition.slug!, definition }
    ])
  );

  posts.forEach((post) => {
    const name = getCategoryName(post);
    const slug = getCategorySlug(post);

    if (!categoryMap.has(slug)) {
      categoryMap.set(slug, { name, slug, definition: null });
    }
  });

  return [...categoryMap.values()].map(({ name, slug, definition }) => {
    const categoryPosts = posts
      .filter((post) => getCategorySlug(post) === slug)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category: slug },
      props: {
        category: name,
        posts: categoryPosts,
        definition
      }
    };
  });
}

const { category, posts, definition } = Astro.props;
const latestPost = posts[0];
const latestDateText = latestPost
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(latestPost.data.pubDate)
  : "";
const topTags = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 8);
const tracks = [...new Set(posts.map((post) => post.data.track).filter(Boolean))];
const contestCount = new Set(posts.map((post) => post.data.contest || post.data.oj).filter(Boolean)).size;
const description =
  definition?.description ?? "这个栏目已经创建，后续会持续补充相关内容。";
const writingFocus =
  definition?.writingFocus ?? "这里会逐步收录同一主题下的相关文章、记录和笔记。";
const exampleTopics = definition?.exampleTopics ?? [];
const pageDescription = categoryPage.pageDescriptionTemplate.replace("{{category}}", category);
---

<Layout title={`${category} | ${site.siteTitle}`} description={pageDescription}>
  <section class="shell page-intro">
    <p class="eyebrow">{categoryPage.pageEyebrow}</p>
    <h1>{category}</h1>
    <p>{description}</p>
    <dl class="page-stats">
      <div>
        <dt>{categoryPage.postsLabel}</dt>
        <dd>{posts.length}</dd>
      </div>
      <div>
        <dt>{categoryPage.contestsLabel}</dt>
        <dd>{contestCount}</dd>
      </div>
      <div>
        <dt>{categoryPage.latestUpdateLabel}</dt>
        <dd>{latestDateText || categoryPage.emptyLatestUpdateText}</dd>
      </div>
    </dl>
  </section>

  <section class="shell category-overview section-block">
    <article class="guide-card">
      <p class="guide-card-label">{categoryPage.overviewLabel}</p>
      <h2>{writingFocus}</h2>
      <p>{categoryPage.overviewBody}</p>
    </article>
    <article class="guide-card">
      <p class="guide-card-label">{categoryPage.commonTagsLabel}</p>
      <div class="tag-cloud">
        {topTags.length > 0 ? topTags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />) : <span class="empty-inline">{categoryPage.commonTagsEmpty}</span>}
      </div>
    </article>
  </section>

  {(tracks.length > 0 || exampleTopics.length > 0) && (
    <section class="shell guide-grid section-block">
      <article class="guide-card">
        <p class="guide-card-label">{categoryPage.commonTracksLabel}</p>
        <h2>{tracks.length > 0 ? tracks.join(" / ") : categoryPage.commonTracksEmpty}</h2>
      </article>
      <article class="guide-card">
        <p class="guide-card-label">{categoryPage.topicsLabel}</p>
        {exampleTopics.length > 0 ? (
          <div class="category-example-row">
            {exampleTopics.map((topic) => (
              <span class="tag-pill">{topic}</span>
            ))}
          </div>
        ) : (
          <p class="empty-inline">{categoryPage.topicsEmpty}</p>
        )}
      </article>
    </section>
  )}

  <section class="shell section-block">
    {posts.length > 0 ? (
      <div class="archive-list">
        {posts.map((post) => <ArchiveRow post={post} />)}
      </div>
    ) : (
      <p class="empty-feed">{categoryPage.emptyFeed}</p>
    )}
  </section>
</Layout>
