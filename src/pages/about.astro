---
import { getCollection } from "astro:content";
import TagPill from "../components/TagPill.astro";
import Layout from "../layouts/Layout.astro";
import { getCategoryName, getCategorySlug, getContestName, getContestSlug, slugifySegment } from "../utils/content";
import { getPageLayouts, getSiteSettings } from "../utils/site";

const site = await getSiteSettings();
const pageLayouts = await getPageLayouts();
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
      }
    >
  >((acc, post) => {
    const name = getCategoryName(post);
    const slug = getCategorySlug(post);
    const previous = acc[slug];

    acc[slug] = {
      name,
      slug,
      count: (previous?.count ?? 0) + 1
    };

    return acc;
  }, {})
)
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, "zh-CN"))
  .slice(0, 4);

const contestPosts = posts.filter((post) => post.data.contest || post.data.oj);
const contests = Object.values(
  contestPosts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
      }
    >
  >((acc, post) => {
    const name = getContestName(post);
    const slug = getContestSlug(post);
    const previous = acc[slug];

    acc[slug] = {
      name,
      slug,
      count: (previous?.count ?? 0) + 1
    };

    return acc;
  }, {})
)
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, "zh-CN"))
  .slice(0, 3);

const totalCategories = new Set(posts.map((post) => getCategoryName(post))).size;
const totalContests = new Set(posts.map((post) => post.data.contest || post.data.oj).filter(Boolean)).size;
const totalTags = new Set(posts.flatMap((post) => post.data.tags)).size;
const tagHighlights = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 10);
const latestPosts = posts.slice(0, 3).map((post) => ({
  ...post,
  dateText: new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit"
  }).format(post.data.pubDate)
}));
const contestsMetaText = site.contestsMeta.replace("{{count}}", String(totalContests));

const aboutSectionTitleDefaults = {
  focus: site.focusTitle,
  writing: site.writingTitle,
  note: site.noteTitle,
  contests: site.contestsLabel,
  "latest-posts": site.latestContentHeading,
  "browse-guides": site.browseGuideLabel
};

const aboutSectionNoteDefaults = {
  focus: "",
  writing: "",
  note: site.aboutNote,
  contests: site.contestsMeta,
  "latest-posts": site.latestContentNote,
  "browse-guides": ""
};

const aboutSections = (pageLayouts.aboutSections?.length
  ? pageLayouts.aboutSections
  : [])
  .filter((section) => section.enabled)
  .map((section, index) => ({
    ...section,
    title: section.title || aboutSectionTitleDefaults[section.type] || `关于板块 ${index + 1}`,
    note: section.note || aboutSectionNoteDefaults[section.type] || "",
    id: slugifySegment(section.anchor || `${section.type}-${index + 1}`)
  }));
---

<Layout title={`关于 | ${site.siteTitle}`} description={site.siteDescription}>
  <section class="shell intro about-intro">
    <div class="hero-card about-hero-card">
      <div class="hero-copy">
        <div class="hero-topline">
          <img class="intro-avatar" src={site.avatarImage || "/avatar.jpg"} alt={site.aboutAvatarAlt} />
          <div>
            <p class="eyebrow">{site.aboutEyebrow}</p>
            <h1>{site.aboutTitle}</h1>
          </div>
        </div>
        {site.aboutIntro.map((paragraph) => <p>{paragraph}</p>)}
        <dl class="page-stats">
          <div>
            <dt>{site.aboutPostsLabel}</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>{site.aboutCategoriesLabel}</dt>
            <dd>{totalCategories}</dd>
          </div>
          <div>
            <dt>{site.aboutTagsLabel}</dt>
            <dd>{totalTags}</dd>
          </div>
        </dl>
      </div>

      <aside class="hero-aside">
        <section class="hero-note-card accent-card">
          <p class="hero-note-label">{site.contentMapLabel}</p>
          <div class="hero-chip-stack">
            {categories.map((category) => (
              <a class="hero-chip" href={`/categories/${category.slug}/`}>
                <span>{category.name}</span>
                <strong>{category.count}</strong>
              </a>
            ))}
          </div>
        </section>

        <section class="hero-note-card">
          <p class="hero-note-label">{site.commonTagsLabel}</p>
          <div class="tag-cloud">
            {tagHighlights.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
          </div>
        </section>
      </aside>
    </div>
  </section>

  {aboutSections.map((section) => (
    <>
      {
        section.type === "focus" && (
          <section class="shell guide-grid section-block" id={section.id}>
            <article class="guide-card focus-list-card">
              <p class="guide-card-label">{site.focusLabel}</p>
              <h2>{section.title}</h2>
              {section.note && <p class="guide-card-meta">{section.note}</p>}
              <ul class="plain-list">
                {site.aboutFocusAreas.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          </section>
        )
      }

      {
        section.type === "writing" && (
          <section class="shell guide-grid section-block" id={section.id}>
            <article class="guide-card focus-list-card">
              <p class="guide-card-label">{site.writingLabel}</p>
              <h2>{section.title}</h2>
              {section.note && <p class="guide-card-meta">{section.note}</p>}
              <ul class="plain-list">
                {site.aboutWritingApproach.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          </section>
        )
      }

      {
        section.type === "note" && (
          <section class="shell about-panel-grid section-block" id={section.id}>
            <article class="guide-card">
              <p class="guide-card-label">{site.noteLabel}</p>
              <h2>{section.title}</h2>
              <p>{section.note || site.aboutNote}</p>
            </article>
          </section>
        )
      }

      {
        section.type === "contests" && (
          <section class="shell about-panel-grid section-block" id={section.id}>
            <article class="guide-card">
              <p class="guide-card-label">{site.contestsLabel}</p>
              <h2>{section.title}</h2>
              <div class="mini-link-list">
                {contests.length > 0 ? (
                  contests.map((contest) => (
                    <a class="mini-link-row" href={`/contests/${contest.slug}/`}>
                      <span>{contest.name}</span>
                      <strong>{contest.count}</strong>
                    </a>
                  ))
                ) : (
                  <p class="empty-inline">{site.contestsEmpty}</p>
                )}
              </div>
              <p class="guide-card-meta">{section.note || contestsMetaText}</p>
            </article>
          </section>
        )
      }

      {
        section.type === "latest-posts" && (
          <section class="shell section-block" id={section.id}>
            <div class="section-head">
              <h2>{section.title}</h2>
              <span class="section-note">{section.note}</span>
            </div>
            <div class="signal-grid">
              {latestPosts.map((post) => (
                <a class="signal-card" href={`/blog/${post.slug}/`}>
                  <p class="signal-label">{[post.data.category, post.data.contest || post.data.oj].filter(Boolean).join(" / ")}</p>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="signal-card-footer">
                    <span>{post.dateText}</span>
                    <span>{post.data.track || post.data.language}</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        section.type === "browse-guides" && (
          <section class="shell guide-grid section-block" id={section.id}>
            {site.browseGuides.map((guide) => (
              <article class="guide-card">
                <p class="guide-card-label">{section.title}</p>
                <h2>{guide.title}</h2>
                <p>{guide.description}</p>
              </article>
            ))}
          </section>
        )
      }
    </>
  ))}
</Layout>
