---
import { getCollection } from "astro:content";
import ArchiveRow from "../components/ArchiveRow.astro";
import TagPill from "../components/TagPill.astro";
import Layout from "../layouts/Layout.astro";
import {
  getCategoryName,
  getCategorySlug,
  getContestCover,
  getContestName,
  getContestSlug,
  slugifySegment
} from "../utils/content";
import { getSiteSettings } from "../utils/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const site = await getSiteSettings();

const wpPosts = posts.filter((post) => post.data.category === "比赛 WP");
const reviewPosts = posts.filter((post) => post.data.category === "赛后复盘");
const summaryPosts = posts.filter((post) => post.data.category === "专题总结");
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];
const tags = allTags.slice(0, 12);
const latest = posts[0];
const featuredPost = posts.find((post) => post.data.featured) ?? latest;
const recentPosts = featuredPost
  ? posts.filter((post) => post.slug !== featuredPost.slug).slice(0, 6)
  : posts.slice(0, 6);
const recentSignalCards = recentPosts.slice(0, 3).map((post) => ({
  ...post,
  dateText: new Intl.DateTimeFormat("zh-CN", {
    month: "2-digit",
    day: "2-digit"
  }).format(post.data.pubDate),
  metaText: post.data.tags.slice(0, 2).join(" / ") || post.data.track || post.data.language
}));
const recentWpPosts = wpPosts.filter((post) => post.slug !== featuredPost?.slug).slice(0, 4);
const recentReviewPosts = reviewPosts.slice(0, 4);
const contestCards = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
        latestTitle: string;
        latestDate: number;
        tracks: Set<string>;
        coverImage: string;
      }
    >
  >((acc, post) => {
    const contestName = getContestName(post);
    const contestSlug = getContestSlug(post);
    const coverImage = getContestCover(post);
    const publishedAt = post.data.pubDate.valueOf();
    const previous = acc[contestSlug];

    if (!previous || publishedAt > previous.latestDate) {
      acc[contestSlug] = {
        name: contestName,
        slug: contestSlug,
        count: (previous?.count ?? 0) + 1,
        latestTitle: post.data.title,
        latestDate: publishedAt,
        tracks: new Set([post.data.track].filter(Boolean)),
        coverImage: coverImage || previous?.coverImage || ""
      };
    } else {
      previous.count += 1;
      if (post.data.track) {
        previous.tracks.add(post.data.track);
      }
      if (!previous.coverImage && coverImage) {
        previous.coverImage = coverImage;
      }
    }

    return acc;
  }, {})
)
  .map((contest) => ({ ...contest, tracks: [...contest.tracks] }))
  .sort((a, b) => b.latestDate - a.latestDate || b.count - a.count)
  .slice(0, 4);
const categoryCards = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
        latestTitle: string;
        latestDate: number;
      }
    >
  >((acc, post) => {
    const name = getCategoryName(post);
    const slug = getCategorySlug(post);
    const previous = acc[slug];
    const publishedAt = post.data.pubDate.valueOf();

    if (!previous || publishedAt > previous.latestDate) {
      acc[slug] = {
        name,
        slug,
        count: (previous?.count ?? 0) + 1,
        latestTitle: post.data.title,
        latestDate: publishedAt
      };
    } else {
      previous.count += 1;
    }

    return acc;
  }, {})
)
  .sort((a, b) => b.count - a.count || b.latestDate - a.latestDate)
  .slice(0, 4);
const categoryCount = new Set(posts.map((post) => getCategoryName(post))).size;
const contestCount = new Set(posts.map((post) => post.data.contest || post.data.oj).filter(Boolean)).size;
const latestDate = latest
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(latest.data.pubDate)
  : "";
const featuredDate = featuredPost
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric"
    }).format(featuredPost.data.pubDate)
  : "";
const heroCategoryLinks = categoryCards.slice(0, 3);
const routeCards = [
  {
    title: "比赛 WP",
    count: wpPosts.length,
    href: `/categories/${slugifySegment("比赛 WP")}/`,
    description: "这里主要收录单题解法、关键 payload、脚本思路和过程记录。",
    latestTitle: wpPosts[0]?.data.title ?? "这个栏目会随着后续更新慢慢补充起来。"
  },
  {
    title: "赛后复盘",
    count: reviewPosts.length,
    href: `/categories/${slugifySegment("赛后复盘")}/`,
    description: "这里会放整场比赛的节奏、失误点、回看总结和补题记录。",
    latestTitle: reviewPosts[0]?.data.title ?? "后面会逐步把整场比赛的复盘内容补上。"
  },
  {
    title: "专题总结",
    count: summaryPosts.length,
    href: `/categories/${slugifySegment("专题总结")}/`,
    description: "这里会整理反复出现的知识点、工具用法和题型笔记。",
    latestTitle: summaryPosts[0]?.data.title ?? "后续会把常见知识点慢慢整理到这里。"
  }
];
---

<Layout title={site.siteTitle} description={site.siteDescription}>
  <section class="shell intro">
    <div class="hero-card">
      <div class="hero-copy">
        <div class="hero-topline">
          <img class="intro-avatar" src="/avatar.jpg" alt="iYuu 的头像" />
          <div>
            <p class="eyebrow">{site.homeEyebrow}</p>
            <h1>{site.homeTitle}</h1>
          </div>
        </div>
        <p class="intro-lead">{site.homeLead}</p>
        {site.homeIntro.map((paragraph) => <p>{paragraph}</p>)}
        <div class="hero-links hero-links-strong">
          <a href="/contests">看比赛分类</a>
          <a href="/categories">看内容分类</a>
          <a href="/blog">看全部文章</a>
          <a href="/tags">看标签</a>
          <a href="/about">看看这个站在写什么</a>
        </div>
        {
          latest && (
            <p class="meta-line hero-update">
              最近更新：<a href={`/blog/${latest.slug}/`}>{latest.data.title}</a> · {latestDate}
            </p>
          )
        }
        <dl class="intro-stats">
          <div>
            <dt>文章</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>比赛</dt>
            <dd>{contestCount}</dd>
          </div>
          <div>
            <dt>分类</dt>
            <dd>{categoryCount}</dd>
          </div>
        </dl>
      </div>

      <aside class="hero-aside">
        <section class="hero-note-card">
          <p class="hero-note-label">浏览方式</p>
          <ul class="hero-note-list">
            <li>比赛页适合按赛事集中查看一整场记录</li>
            <li>分类页适合按主题浏览不同方向的内容</li>
            <li>标签页适合快速定位具体知识点</li>
          </ul>
        </section>

        <section class="hero-note-card accent-card">
          <p class="hero-note-label">常用入口</p>
          <div class="hero-chip-stack">
            {heroCategoryLinks.map((category) => (
              <a class="hero-chip" href={`/categories/${category.slug}/`}>
                <span>{category.name}</span>
                <strong>{category.count}</strong>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>

  <section class="shell home-layout">
    <aside class="index-column">
      <div class="site-index">
        <p class="index-title">浏览索引</p>
        <ul class="index-list">
          <li><a href="#featured">先看这一篇</a></li>
          <li><a href="#fresh">最近在补这些</a></li>
          <li><a href="#writeups">最近比赛 WP</a></li>
          <li><a href="#contests">按比赛分类</a></li>
          <li><a href="#routes">内容路线图</a></li>
          <li><a href="#reviews">赛后复盘</a></li>
          <li><a href="#tags">标签</a></li>
        </ul>
        <p class="index-meta">目前 {posts.length} 篇，最近更新在 {latestDate || "这几天"}。</p>
        <div class="index-block">
          <p class="index-label">内容方向</p>
          <p class="index-text">这里主要更新比赛 WP、电子取证题分析、赛后复盘，以及比赛中反复出现的知识点整理。</p>
        </div>
      </div>
    </aside>

    <div class="home-grid">
      <div class="main-column">
        {
          featuredPost && (
            <section class="section" id="featured">
              <div class="section-head">
                <h2>先看这一篇</h2>
                <span class="section-note">{featuredDate}</span>
              </div>
              <article class="featured-card">
                <p class="featured-kicker">
                  {[featuredPost.data.category, featuredPost.data.contest || featuredPost.data.oj, featuredPost.data.track]
                    .filter(Boolean)
                    .join(" / ")}
                </p>
                <h3>
                  <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
                </h3>
                <p>{featuredPost.data.description}</p>
                <div class="featured-meta">
                  <span>{featuredPost.data.language}</span>
                  <span>{featuredPost.data.tags.length} 个标签</span>
                </div>
              </article>
            </section>
          )
        }

        <section class="section" id="fresh">
          <div class="section-head">
            <h2>最近在补这些</h2>
            <span class="section-note">把零散记录慢慢补成一个自己的知识库</span>
          </div>
          <div class="signal-grid">
            {recentSignalCards.map((post) => (
              <a class="signal-card" href={`/blog/${post.slug}/`}>
                <p class="signal-label">{[post.data.category, post.data.contest || post.data.oj].filter(Boolean).join(" / ")}</p>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="signal-card-footer">
                  <span>{post.dateText}</span>
                  <span>{post.metaText}</span>
                </div>
              </a>
            ))}
          </div>
        </section>

        <section class="section" id="writeups">
          <div class="section-head">
            <h2>最近比赛 WP</h2>
            <a class="section-link" href="/blog">查看归档</a>
          </div>
          {
            recentWpPosts.length > 0 ? (
              <div class="archive-list">
                {recentWpPosts.map((post) => <ArchiveRow post={post} />)}
              </div>
            ) : (
              <p class="empty-feed">目前公开的比赛 WP 还不多，先从上面那篇开始，后面会慢慢把每场比赛的过程补起来。</p>
            )
          }
        </section>

        <section class="section" id="contests">
          <div class="section-head">
            <h2>按比赛分类</h2>
            <a class="section-link" href="/contests">查看全部比赛</a>
          </div>
          <div class="track-grid">
            {contestCards.map((contest) => (
              <a
                class:list={["track-board", contest.coverImage ? "has-cover" : ""]}
                href={`/contests/${contest.slug}/`}
                style={contest.coverImage ? `--contest-cover: url('${contest.coverImage}')` : undefined}
              >
                <div class="track-board-content">
                  <p class="track-name">比赛</p>
                  <strong>{contest.name}</strong>
                  <p>{contest.count} 篇文章 · {contest.tracks.join(" / ") || "待补充方向"}</p>
                  <p>最近一篇：{contest.latestTitle}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <section class="section" id="categories">
          <div class="section-head">
            <h2>按内容分类</h2>
            <a class="section-link" href="/categories">查看全部分类</a>
          </div>
          <div class="tag-index-grid compact-grid">
            {categoryCards.map((category) => (
              <a class="tag-board" href={`/categories/${category.slug}/`}>
                <div class="tag-board-head">
                  <span class="tag-board-name">{category.name}</span>
                  <strong>{category.count}</strong>
                </div>
                <p>最新内容：{category.latestTitle}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="section" id="routes">
          <div class="section-head">
            <h2>内容路线图</h2>
            <span class="section-note">可以从不同内容类型进入，按自己感兴趣的方向浏览</span>
          </div>
          <div class="route-grid">
            {routeCards.map((route) => (
              <a class="route-card" href={route.count > 0 ? route.href : "/categories"}>
                <div class="route-card-head">
                  <span>{route.title}</span>
                  <strong>{route.count}</strong>
                </div>
                <p>{route.description}</p>
                <p class="route-card-meta">最近内容：{route.latestTitle}</p>
              </a>
            ))}
          </div>
        </section>
      </div>

      <aside class="side-column">
        <section class="section side-note">
          <h2>更新方式</h2>
          <p>这里会尽量把题目背景、分析过程和关键结论写清楚，让每篇文章都既方便阅读，也方便后续回看。</p>
        </section>

        <section class="section side-note">
          <h2>持续补充中</h2>
          <p>除了比赛 WP，这里也会慢慢补充赛后复盘、专题总结和学习过程中的记录，让内容越来越完整。</p>
        </section>

        <section class="section" id="reviews">
          <h2>赛后复盘</h2>
          {
            recentReviewPosts.length > 0 ? (
              <ul class="link-list note-list">
                {recentReviewPosts.map((post) => (
                  <li>
                    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                    <span>{post.data.contest || post.data.oj || post.data.track}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty-feed">这里以后会放一场比赛打完后的整体复盘，而不只是单题 WP。</p>
            )
          }
        </section>

        <section class="section" id="tags">
          <h2>标签</h2>
          <div class="tag-cloud">
            {tags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
          </div>
        </section>

        <section class="section">
          <h2>专题总结</h2>
          {
            summaryPosts.length > 0 ? (
              <ul class="link-list note-list">
                {summaryPosts.slice(0, 4).map((post) => (
                  <li>
                    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                    <span>{post.data.track || post.data.category}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty-feed">等比赛文章积累起来之后，再把常出现的知识点单独整理成专题。</p>
            )
          }
        </section>
      </aside>
    </div>
  </section>
</Layout>
