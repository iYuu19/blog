---
import { getCollection } from "astro:content";
import ArchiveRow from "../components/ArchiveRow.astro";
import TagPill from "../components/TagPill.astro";
import Layout from "../layouts/Layout.astro";
import {
  getCategoryName,
  getCategorySlug,
  getContestCover,
  getContestName,
  getContestSlug,
  slugifySegment
} from "../utils/content";
import { getSiteSettings } from "../utils/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const site = await getSiteSettings();

const wpPosts = posts.filter((post) => post.data.category === "比赛 WP");
const reviewPosts = posts.filter((post) => post.data.category === "赛后复盘");
const summaryPosts = posts.filter((post) => post.data.category === "专题总结");
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];
const tags = allTags.slice(0, 12);
const latest = posts[0];
const featuredPost = posts.find((post) => post.data.featured) ?? latest;
const recentPosts = featuredPost
  ? posts.filter((post) => post.slug !== featuredPost.slug).slice(0, 6)
  : posts.slice(0, 6);
const recentSignalCards = recentPosts.slice(0, 3).map((post) => ({
  ...post,
  dateText: new Intl.DateTimeFormat("zh-CN", {
    month: "2-digit",
    day: "2-digit"
  }).format(post.data.pubDate),
  metaText: post.data.tags.slice(0, 2).join(" / ") || post.data.track || post.data.language
}));
const recentWpPosts = wpPosts.filter((post) => post.slug !== featuredPost?.slug).slice(0, 4);
const recentReviewPosts = reviewPosts.slice(0, 4);
const contestCards = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
        latestTitle: string;
        latestDate: number;
        tracks: Set<string>;
        coverImage: string;
      }
    >
  >((acc, post) => {
    const contestName = getContestName(post);
    const contestSlug = getContestSlug(post);
    const coverImage = getContestCover(post);
    const publishedAt = post.data.pubDate.valueOf();
    const previous = acc[contestSlug];

    if (!previous || publishedAt > previous.latestDate) {
      acc[contestSlug] = {
        name: contestName,
        slug: contestSlug,
        count: (previous?.count ?? 0) + 1,
        latestTitle: post.data.title,
        latestDate: publishedAt,
        tracks: new Set([post.data.track].filter(Boolean)),
        coverImage: coverImage || previous?.coverImage || ""
      };
    } else {
      previous.count += 1;
      if (post.data.track) {
        previous.tracks.add(post.data.track);
      }
      if (!previous.coverImage && coverImage) {
        previous.coverImage = coverImage;
      }
    }

    return acc;
  }, {})
)
  .map((contest) => ({ ...contest, tracks: [...contest.tracks] }))
  .sort((a, b) => b.latestDate - a.latestDate || b.count - a.count)
  .slice(0, 4);
const categoryCards = Object.values(
  posts.reduce<
    Record<
      string,
      {
        name: string;
        slug: string;
        count: number;
        latestTitle: string;
        latestDate: number;
      }
    >
  >((acc, post) => {
    const name = getCategoryName(post);
    const slug = getCategorySlug(post);
    const previous = acc[slug];
    const publishedAt = post.data.pubDate.valueOf();

    if (!previous || publishedAt > previous.latestDate) {
      acc[slug] = {
        name,
        slug,
        count: (previous?.count ?? 0) + 1,
        latestTitle: post.data.title,
        latestDate: publishedAt
      };
    } else {
      previous.count += 1;
    }

    return acc;
  }, {})
)
  .sort((a, b) => b.count - a.count || b.latestDate - a.latestDate)
  .slice(0, 4);
const categoryCount = new Set(posts.map((post) => getCategoryName(post))).size;
const contestCount = new Set(posts.map((post) => post.data.contest || post.data.oj).filter(Boolean)).size;
const latestDate = latest
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(latest.data.pubDate)
  : "";
const featuredDate = featuredPost
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric"
    }).format(featuredPost.data.pubDate)
  : "";
const heroCategoryLinks = categoryCards.slice(0, 3);
const routeSourceMap = new Map([
  ["比赛 WP", wpPosts],
  ["赛后复盘", reviewPosts],
  ["专题总结", summaryPosts]
]);
const routeCards = site.routeCards.map((route) => {
  const routePosts = routeSourceMap.get(route.title) ?? [];

  return {
    ...route,
    count: routePosts.length,
    href: `/categories/${slugifySegment(route.title)}/`,
    latestTitle: routePosts[0]?.data.title ?? route.emptyLatestTitle
  };
});

const sectionTitleDefaults = {
  featured: site.featuredHeading,
  fresh: site.freshHeading,
  writeups: site.writeupsHeading,
  contests: site.contestsHeading,
  categories: site.categoriesHeading,
  routes: site.routesHeading,
  reviews: site.reviewsHeading,
  tags: site.tagsHeading,
  summaries: site.summariesHeading,
  note: ""
};

const sectionNoteDefaults = {
  featured: featuredDate,
  fresh: site.freshNote,
  writeups: "",
  contests: "",
  categories: "",
  routes: site.routesNote,
  reviews: "",
  tags: "",
  summaries: "",
  note: ""
};

const sectionLinkDefaults = {
  featured: { label: "", href: "" },
  fresh: { label: "", href: "" },
  writeups: { label: "查看归档", href: "/blog" },
  contests: { label: "查看全部比赛", href: "/contests" },
  categories: { label: "查看全部分类", href: "/categories" },
  routes: { label: "", href: "" },
  reviews: { label: "", href: "" },
  tags: { label: "", href: "" },
  summaries: { label: "", href: "" },
  note: { label: "", href: "" }
};

const applyTemplate = (template: string, replacements: Record<string, string>) =>
  Object.entries(replacements).reduce(
    (result, [key, value]) => result.replaceAll(`{{${key}}}`, value),
    template
  );

const baseHomeSections = site.homeSections?.length ? site.homeSections : [];
const homeSections = baseHomeSections
  .filter((section) => section.enabled)
  .map((section, index) => {
    const title =
      section.title || sectionTitleDefaults[section.type] || `板块 ${index + 1}`;
    const note = section.note || sectionNoteDefaults[section.type] || "";
    const linkDefaults = sectionLinkDefaults[section.type];
    const anchorSeed = section.anchor || `${section.type}-${index + 1}`;

    return {
      ...section,
      title,
      note,
      linkLabel: section.linkLabel || linkDefaults.label,
      linkHref: section.linkHref || linkDefaults.href,
      id: slugifySegment(anchorSeed) || `section-${index + 1}`
    };
  })
  .filter((section) => section.type !== "note" || section.title || section.note);

const mainSections = homeSections.filter((section) => section.placement !== "side");
const sideSections = homeSections.filter((section) => section.placement === "side");
const indexMetaText = applyTemplate(site.homeIndexMetaTemplate, {
  count: String(posts.length),
  date: latestDate || "最近"
});
---

<Layout title={site.siteTitle} description={site.siteDescription}>
  <section class="shell intro">
    <div class="hero-card">
      <div class="hero-copy">
        <div class="hero-topline">
          <img class="intro-avatar" src="/avatar.jpg" alt="iYuu 的头像" />
          <div>
            <p class="eyebrow">{site.homeEyebrow}</p>
            <h1>{site.homeTitle}</h1>
          </div>
        </div>
        <p class="intro-lead">{site.homeLead}</p>
        {site.homeIntro.map((paragraph) => <p>{paragraph}</p>)}
        <div class="hero-links hero-links-strong">
          {site.heroLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
        {
          latest && (
            <p class="meta-line hero-update">
              最近更新：<a href={`/blog/${latest.slug}/`}>{latest.data.title}</a> · {latestDate}
            </p>
          )
        }
        <dl class="intro-stats">
          <div>
            <dt>文章</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>比赛</dt>
            <dd>{contestCount}</dd>
          </div>
          <div>
            <dt>分类</dt>
            <dd>{categoryCount}</dd>
          </div>
        </dl>
      </div>

      <aside class="hero-aside">
        <section class="hero-note-card">
          <p class="hero-note-label">{site.browseTitle}</p>
          <ul class="hero-note-list">
            {site.browseTips.map((tip) => <li>{tip}</li>)}
          </ul>
        </section>

        <section class="hero-note-card accent-card">
          <p class="hero-note-label">{site.commonEntryTitle}</p>
          <div class="hero-chip-stack">
            {heroCategoryLinks.map((category) => (
              <a class="hero-chip" href={`/categories/${category.slug}/`}>
                <span>{category.name}</span>
                <strong>{category.count}</strong>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>

  <section class="shell home-layout">
    <aside class="index-column">
      <div class="site-index">
        <p class="index-title">{site.homeIndexTitle}</p>
        <ul class="index-list">
          {homeSections.map((section) => (
            <li><a href={`#${section.id}`}>{section.title}</a></li>
          ))}
        </ul>
        <p class="index-meta">{indexMetaText}</p>
        <div class="index-block">
          <p class="index-label">{site.homeIndexFocusLabel}</p>
          <p class="index-text">{site.homeIndexFocusText}</p>
        </div>
      </div>
    </aside>

    <div class="home-grid">
      <div class="main-column">
        {mainSections.map((section) => (
          <>
            {
              section.type === "featured" &&
                featuredPost && (
                  <section class="section" id={section.id}>
                    <div class="section-head">
                      <h2>{section.title}</h2>
                      <span class="section-note">{section.note}</span>
                    </div>
                    <article class="featured-card">
                      <p class="featured-kicker">
                        {[featuredPost.data.category, featuredPost.data.contest || featuredPost.data.oj, featuredPost.data.track]
                          .filter(Boolean)
                          .join(" / ")}
                      </p>
                      <h3>
                        <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
                      </h3>
                      <p>{featuredPost.data.description}</p>
                      <div class="featured-meta">
                        <span>{featuredPost.data.language}</span>
                        <span>{featuredPost.data.tags.length} 个标签</span>
                      </div>
                    </article>
                  </section>
                )
            }

            {
              section.type === "fresh" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    <span class="section-note">{section.note}</span>
                  </div>
                  <div class="signal-grid">
                    {recentSignalCards.map((post) => (
                      <a class="signal-card" href={`/blog/${post.slug}/`}>
                        <p class="signal-label">{[post.data.category, post.data.contest || post.data.oj].filter(Boolean).join(" / ")}</p>
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                        <div class="signal-card-footer">
                          <span>{post.dateText}</span>
                          <span>{post.metaText}</span>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "writeups" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  {
                    recentWpPosts.length > 0 ? (
                      <div class="archive-list">
                        {recentWpPosts.map((post) => <ArchiveRow post={post} />)}
                      </div>
                    ) : (
                      <p class="empty-feed">{site.writeupsEmpty}</p>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "contests" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  <div class="track-grid">
                    {contestCards.map((contest) => (
                      <a
                        class:list={["track-board", contest.coverImage ? "has-cover" : ""]}
                        href={`/contests/${contest.slug}/`}
                        style={contest.coverImage ? `--contest-cover: url('${contest.coverImage}')` : undefined}
                      >
                        <div class="track-board-content">
                          <p class="track-name">比赛</p>
                          <strong>{contest.name}</strong>
                          <p>{contest.count} 篇文章 · {contest.tracks.join(" / ") || "待补充方向"}</p>
                          <p>最近一篇：{contest.latestTitle}</p>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "categories" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  <div class="tag-index-grid compact-grid">
                    {categoryCards.map((category) => (
                      <a class="tag-board" href={`/categories/${category.slug}/`}>
                        <div class="tag-board-head">
                          <span class="tag-board-name">{category.name}</span>
                          <strong>{category.count}</strong>
                        </div>
                        <p>最新内容：{category.latestTitle}</p>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "routes" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    <span class="section-note">{section.note}</span>
                  </div>
                  <div class="route-grid">
                    {routeCards.map((route) => (
                      <a class="route-card" href={route.count > 0 ? route.href : "/categories"}>
                        <div class="route-card-head">
                          <span>{route.title}</span>
                          <strong>{route.count}</strong>
                        </div>
                        <p>{route.description}</p>
                        <p class="route-card-meta">最近内容：{route.latestTitle}</p>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "note" && (
                <section class="section side-note" id={section.id}>
                  <h2>{section.title}</h2>
                  <p>{section.note}</p>
                  {
                    section.linkLabel && section.linkHref && (
                      <a class="section-link" href={section.linkHref}>
                        {section.linkLabel}
                      </a>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "reviews" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  {
                    recentReviewPosts.length > 0 ? (
                      <ul class="link-list note-list">
                        {recentReviewPosts.map((post) => (
                          <li>
                            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                            <span>{post.data.contest || post.data.oj || post.data.track}</span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="empty-feed">{site.reviewsEmpty}</p>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "tags" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  <div class="tag-cloud">
                    {tags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
                  </div>
                </section>
              )
            }

            {
              section.type === "summaries" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  {
                    summaryPosts.length > 0 ? (
                      <ul class="link-list note-list">
                        {summaryPosts.slice(0, 4).map((post) => (
                          <li>
                            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                            <span>{post.data.track || post.data.category}</span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="empty-feed">{site.summariesEmpty}</p>
                    )
                  }
                </section>
              )
            }
          </>
        ))}
      </div>

      <aside class="side-column">
        {sideSections.map((section) => (
          <>
            {
              section.type === "note" && (
                <section class="section side-note" id={section.id}>
                  <h2>{section.title}</h2>
                  <p>{section.note}</p>
                  {
                    section.linkLabel && section.linkHref && (
                      <a class="section-link" href={section.linkHref}>
                        {section.linkLabel}
                      </a>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "reviews" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  {
                    recentReviewPosts.length > 0 ? (
                      <ul class="link-list note-list">
                        {recentReviewPosts.map((post) => (
                          <li>
                            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                            <span>{post.data.contest || post.data.oj || post.data.track}</span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="empty-feed">{site.reviewsEmpty}</p>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "tags" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  <div class="tag-cloud">
                    {tags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
                  </div>
                </section>
              )
            }

            {
              section.type === "summaries" && (
                <section class="section" id={section.id}>
                  <h2>{section.title}</h2>
                  {
                    summaryPosts.length > 0 ? (
                      <ul class="link-list note-list">
                        {summaryPosts.slice(0, 4).map((post) => (
                          <li>
                            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                            <span>{post.data.track || post.data.category}</span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="empty-feed">{site.summariesEmpty}</p>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "featured" &&
                featuredPost && (
                  <section class="section" id={section.id}>
                    <div class="section-head">
                      <h2>{section.title}</h2>
                      <span class="section-note">{section.note}</span>
                    </div>
                    <article class="featured-card">
                      <p class="featured-kicker">
                        {[featuredPost.data.category, featuredPost.data.contest || featuredPost.data.oj, featuredPost.data.track]
                          .filter(Boolean)
                          .join(" / ")}
                      </p>
                      <h3>
                        <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
                      </h3>
                      <p>{featuredPost.data.description}</p>
                    </article>
                  </section>
                )
            }

            {
              section.type === "fresh" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    <span class="section-note">{section.note}</span>
                  </div>
                  <div class="signal-grid">
                    {recentSignalCards.map((post) => (
                      <a class="signal-card" href={`/blog/${post.slug}/`}>
                        <p class="signal-label">{[post.data.category, post.data.contest || post.data.oj].filter(Boolean).join(" / ")}</p>
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "writeups" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  {
                    recentWpPosts.length > 0 ? (
                      <div class="archive-list">
                        {recentWpPosts.map((post) => <ArchiveRow post={post} />)}
                      </div>
                    ) : (
                      <p class="empty-feed">{site.writeupsEmpty}</p>
                    )
                  }
                </section>
              )
            }

            {
              section.type === "contests" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  <div class="track-grid">
                    {contestCards.map((contest) => (
                      <a
                        class:list={["track-board", contest.coverImage ? "has-cover" : ""]}
                        href={`/contests/${contest.slug}/`}
                        style={contest.coverImage ? `--contest-cover: url('${contest.coverImage}')` : undefined}
                      >
                        <div class="track-board-content">
                          <p class="track-name">比赛</p>
                          <strong>{contest.name}</strong>
                          <p>{contest.count} 篇文章 · {contest.tracks.join(" / ") || "待补充方向"}</p>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "categories" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    {
                      section.linkLabel && section.linkHref && (
                        <a class="section-link" href={section.linkHref}>
                          {section.linkLabel}
                        </a>
                      )
                    }
                  </div>
                  <div class="tag-index-grid compact-grid">
                    {categoryCards.map((category) => (
                      <a class="tag-board" href={`/categories/${category.slug}/`}>
                        <div class="tag-board-head">
                          <span class="tag-board-name">{category.name}</span>
                          <strong>{category.count}</strong>
                        </div>
                        <p>最新内容：{category.latestTitle}</p>
                      </a>
                    ))}
                  </div>
                </section>
              )
            }

            {
              section.type === "routes" && (
                <section class="section" id={section.id}>
                  <div class="section-head">
                    <h2>{section.title}</h2>
                    <span class="section-note">{section.note}</span>
                  </div>
                  <div class="route-grid">
                    {routeCards.map((route) => (
                      <a class="route-card" href={route.count > 0 ? route.href : "/categories"}>
                        <div class="route-card-head">
                          <span>{route.title}</span>
                          <strong>{route.count}</strong>
                        </div>
                        <p>{route.description}</p>
                      </a>
                    ))}
                  </div>
                </section>
