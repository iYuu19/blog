---
import { getCollection, render } from "astro:content";
import ArticleTocTree from "../../components/ArticleTocTree.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import Layout from "../../layouts/Layout.astro";
import TagPill from "../../components/TagPill.astro";
import { getContestSlug } from "../../utils/content";
import { getSiteSettings } from "../../utils/site";

interface TocNode {
  depth: number;
  slug: string;
  text: string;
  children: TocNode[];
}

function estimateReadMinutes(markdown: string) {
  const plainText = markdown
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/[#>*_\-\n\r]/g, " ")
    .replace(/\s+/g, "");

  return Math.max(1, Math.round(plainText.length / 480));
}

function buildTocTree(items: Array<{ depth: number; slug: string; text: string }>) {
  const root: TocNode[] = [];
  const stack: TocNode[] = [];

  for (const item of items) {
    const node: TocNode = {
      ...item,
      children: []
    };

    while (stack.length > 0 && stack[stack.length - 1].depth >= item.depth) {
      stack.pop();
    }

    if (stack.length === 0) {
      root.push(node);
    } else {
      stack[stack.length - 1].children.push(node);
    }

    stack.push(node);
  }

  return root;
}

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const site = await getSiteSettings();
const { Content, headings } = await render(post);
const dateText = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric"
}).format(post.data.pubDate);
const updatedDateText = post.data.updatedDate
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric"
    }).format(post.data.updatedDate)
  : null;
const difficultyClassMap: Record<string, string> = {
  Easy: "difficulty-easy",
  Medium: "difficulty-medium",
  Hard: "difficulty-hard",
  Notes: "difficulty-notes"
};

const difficultyClass = difficultyClassMap[post.data.difficulty] ?? "difficulty-notes";
const contestLabel = post.data.contest || post.data.oj || null;
const contestHref = contestLabel ? `/contests/${getContestSlug(post)}/` : null;
const tocItems = headings.filter(({ depth, slug, text }) => depth >= 2 && depth <= 4 && slug && text);
const tocTree = buildTocTree(tocItems);
const readingMinutes = estimateReadMinutes(post.body);
---

<Layout
  title={`${post.data.title} | iYuu Notes`}
  description={post.data.description}
  socialImage={post.data.coverImage || site.defaultCoverImage || site.defaultSocialImage}
>
  <section class="shell article-layout fade-up">
    {
      tocItems.length > 0 && (
        <aside class="index-column article-index-column">
          <div class="site-index article-index">
            <p class="index-title">本文目录</p>
            <p class="article-index-meta">{tocItems.length} sections · {readingMinutes} min read</p>
            <ArticleTocTree nodes={tocTree} />
          </div>
        </aside>
      )
    }

    <article class="article-shell">
      <header class="article-header">
        <p class="article-back">
          <a href="/blog">返回文章列表</a>
        </p>
        <p class="eyebrow">{post.data.category}</p>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
        <div class="article-context">
          {contestLabel && (contestHref ? <a href={contestHref}>{contestLabel}</a> : <span>{contestLabel}</span>)}
          {post.data.track && <span>{post.data.track}</span>}
        </div>
        <div class="article-meta">
          <span>发布于 {dateText}</span>
          {updatedDateText && <span>更新于 {updatedDateText}</span>}
          <span>{readingMinutes} min read</span>
          <span class:list={["difficulty-pill", difficultyClass]}>{post.data.difficulty}</span>
          <span>{post.data.language}</span>
        </div>
        <div class="tag-row">
          {post.data.tags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
        </div>
      </header>

      <div class="article-body prose">
        <Content />
      </div>

      <GiscusComments />
    </article>
  </section>

  {
    tocItems.length > 0 && (
      <script is:inline>
        (() => {
          const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
          if (tocLinks.length === 0) return;
          const scrollRoot = document.documentElement;
          const tocNodes = Array.from(document.querySelectorAll("[data-toc-node]"));
          let activeId = "";
          let scrollAnimationFrame = 0;

          const headingEntries = tocLinks
            .map((link) => {
              const id = link.getAttribute("data-toc-link");
              const heading = id ? document.getElementById(id) : null;
              return heading ? { id, link, heading } : null;
            })
            .filter(Boolean);

          if (headingEntries.length === 0) return;

          const setActive = (id) => {
            if (!id) return;
            const currentEntry = headingEntries.find((entry) => entry.id === id);
            if (!currentEntry) return;
            activeId = id;

            const activeTrailIds = new Set();
            let currentNode = currentEntry.link.closest("[data-toc-node]");
            while (currentNode instanceof HTMLElement) {
              const nodeId = currentNode.dataset.tocNode;
              if (nodeId) {
                activeTrailIds.add(nodeId);
              }

              currentNode = currentNode.parentElement?.closest("[data-toc-node]") ?? null;
            }

            for (const entry of headingEntries) {
              const isActive = entry.id === id;
              const isTrail = activeTrailIds.has(entry.id);
              entry.link.classList.toggle("is-active", isActive);
              entry.link.classList.toggle("is-trail", isTrail);
              if (isActive) {
                entry.link.scrollIntoView({
                  behavior: "smooth",
                  block: "nearest",
                  inline: "nearest"
                });
              }
            }

            for (const node of tocNodes) {
              if (!(node instanceof HTMLElement)) continue;
              const nodeId = node.dataset.tocNode || "";
              const branch = node.querySelector(":scope > [data-toc-branch]");
              const isCurrent = nodeId === id;
              const isTrail = activeTrailIds.has(nodeId);

              node.classList.toggle("is-current", isCurrent);
              node.classList.toggle("is-trail", isTrail);
              if (branch instanceof HTMLElement) {
                branch.classList.toggle("is-open", isTrail);
              }
            }
          };

          const smoothScrollTo = (targetTop) => {
            if (scrollAnimationFrame) {
              cancelAnimationFrame(scrollAnimationFrame);
              scrollAnimationFrame = 0;
            }

            const startTop = window.scrollY;
            const distance = targetTop - startTop;
            if (Math.abs(distance) < 2) {
              window.scrollTo(0, targetTop);
              return;
            }

            const duration = 420;
            const startTime = performance.now();
            const easeInOutCubic = (progress) =>
              progress < 0.5
                ? 4 * progress * progress * progress
                : 1 - Math.pow(-2 * progress + 2, 3) / 2;

            const step = (now) => {
              const elapsed = now - startTime;
              const progress = Math.min(1, elapsed / duration);
              const eased = easeInOutCubic(progress);
              window.scrollTo(0, Math.round(startTop + distance * eased));

              if (progress < 1) {
                scrollAnimationFrame = requestAnimationFrame(step);
              } else {
                scrollAnimationFrame = 0;
              }
            };

            scrollAnimationFrame = requestAnimationFrame(step);
          };

          const jumpToHeading = (entry) => {
            const scrollPaddingTop = Number.parseFloat(getComputedStyle(scrollRoot).scrollPaddingTop) || 0;
            const targetTop = Math.max(0, window.scrollY + entry.heading.getBoundingClientRect().top - scrollPaddingTop);
            const nextHash = entry.link.getAttribute("href") || `#${entry.id}`;

            setActive(entry.id);
            history.replaceState(null, "", nextHash);
            smoothScrollTo(targetTop);
          };

          const observer = new IntersectionObserver(
            (entries) => {
              const visible = entries
                .filter((entry) => entry.isIntersecting)
                .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

              if (visible.length > 0) {
                setActive(visible[0].target.id);
              }
            },
            {
              rootMargin: "-18% 0px -64% 0px",
              threshold: [0, 1]
            }
          );

          for (const entry of headingEntries) {
            observer.observe(entry.heading);
            entry.link.addEventListener("click", (event) => {
              event.preventDefault();
              jumpToHeading(entry);
            });
          }

          setActive(headingEntries[0].id);
        })();
      </script>
    )
  }

  <script is:inline>
    (() => {
      const codeBlocks = Array.from(document.querySelectorAll(".article-body pre"));
      if (codeBlocks.length === 0) return;

      for (const block of codeBlocks) {
        if (block.querySelector(".copy-code-button")) continue;

        const button = document.createElement("button");
        button.type = "button";
        button.className = "copy-code-button";
        button.textContent = "复制代码";

        button.addEventListener("click", async () => {
          const code = block.querySelector("code");
          const text = code ? code.innerText : block.innerText;
          if (!text) return;

          try {
            await navigator.clipboard.writeText(text);
            button.textContent = "已复制";
            window.setTimeout(() => {
              button.textContent = "复制代码";
            }, 1600);
          } catch (error) {
            console.error(error);
            button.textContent = "复制失败";
            window.setTimeout(() => {
              button.textContent = "复制代码";
            }, 1600);
          }
        });

        block.appendChild(button);
      }
    })();
  </script>

  <script is:inline>
    (() => {
      const articleBody = document.querySelector(".article-body");
      if (!articleBody) return;

      const images = Array.from(articleBody.querySelectorAll("img"));
      if (images.length === 0) return;

      const overlay = document.createElement("div");
      overlay.className = "image-lightbox";
      overlay.setAttribute("hidden", "hidden");
      overlay.innerHTML = `
        <div class="image-lightbox-toolbar">
          <a class="image-lightbox-open" href="#" target="_blank" rel="noreferrer">打开原图</a>
          <button type="button" class="image-lightbox-close" aria-label="关闭预览">×</button>
        </div>
        <div class="image-lightbox-stage">
          <div class="image-lightbox-canvas">
            <img class="image-lightbox-image" alt="" />
          </div>
        </div>
        <p class="image-lightbox-tip">滚轮缩放，按住鼠标拖动查看，双击图片恢复初始大小</p>
      `;

      const overlayImage = overlay.querySelector(".image-lightbox-image");
      const openOriginalLink = overlay.querySelector(".image-lightbox-open");
      const closeButton = overlay.querySelector(".image-lightbox-close");
      const stage = overlay.querySelector(".image-lightbox-stage");
      let imageScale = 1;
      let baseWidth = 0;
      let baseHeight = 0;
      let offsetX = 0;
      let offsetY = 0;
      let activePointerId = null;
      let dragStartX = 0;
      let dragStartY = 0;
      let dragOriginX = 0;
      let dragOriginY = 0;

      const markZoomableImages = () => {
        for (const image of articleBody.querySelectorAll("img")) {
          image.classList.add("article-zoomable-image");
        }
      };

      const syncDragState = () => {
        const isZoomed = imageScale > 1.01;
        stage.classList.toggle("is-zoomed", isZoomed);
        overlayImage.classList.toggle("is-zoomed", isZoomed);
      };

      const clampOffset = () => {
        if (!baseWidth || !baseHeight) {
          offsetX = 0;
          offsetY = 0;
          return;
        }

        const maxOffsetX = Math.max(0, (baseWidth * imageScale - stage.clientWidth) / 2);
        const maxOffsetY = Math.max(0, (baseHeight * imageScale - stage.clientHeight) / 2);
        offsetX = Math.min(maxOffsetX, Math.max(-maxOffsetX, offsetX));
        offsetY = Math.min(maxOffsetY, Math.max(-maxOffsetY, offsetY));
      };

      const applyTransform = () => {
        if (!(overlayImage instanceof HTMLImageElement)) return;
        clampOffset();
        overlayImage.style.transform = `translate3d(${offsetX}px, ${offsetY}px, 0) scale(${imageScale})`;
        syncDragState();
      };

      const resetZoom = () => {
        imageScale = 1;
        offsetX = 0;
        offsetY = 0;
        applyTransform();
      };

      const stopDragging = () => {
        activePointerId = null;
        stage.classList.remove("is-dragging");
      };

      const setScaleAroundPoint = (nextScale, clientX, clientY) => {
        if (!baseWidth || !baseHeight || nextScale === imageScale) return;

        const stageRect = stage.getBoundingClientRect();
        const pointerX = clientX - stageRect.left - stageRect.width / 2;
        const pointerY = clientY - stageRect.top - stageRect.height / 2;
        const ratio = nextScale / imageScale;

        offsetX = pointerX - (pointerX - offsetX) * ratio;
        offsetY = pointerY - (pointerY - offsetY) * ratio;
        imageScale = nextScale;
        applyTransform();
      };

      const closeLightbox = () => {
        overlay.setAttribute("hidden", "hidden");
        overlayImage.removeAttribute("src");
        overlayImage.removeAttribute("alt");
        overlayImage.style.removeProperty("transform");
        openOriginalLink.setAttribute("href", "#");
        stopDragging();
        baseWidth = 0;
        baseHeight = 0;
        imageScale = 1;
        offsetX = 0;
        offsetY = 0;
        document.body.classList.remove("lightbox-open");
      };

      const openLightbox = (src, alt) => {
        overlayImage.src = src;
        overlayImage.alt = alt || "";
        openOriginalLink.href = src;
        overlay.removeAttribute("hidden");
        document.body.classList.add("lightbox-open");
      };

      overlay.addEventListener("click", (event) => {
        if (event.target === overlay) {
          closeLightbox();
        }
      });

      closeButton.addEventListener("click", closeLightbox);
      overlayImage.addEventListener("dblclick", resetZoom);

      overlayImage.addEventListener("load", () => {
        stopDragging();
        overlayImage.style.removeProperty("transform");
        requestAnimationFrame(() => {
          baseWidth = overlayImage.clientWidth;
          baseHeight = overlayImage.clientHeight;
          resetZoom();
        });
      });

      stage.addEventListener(
        "wheel",
        (event) => {
          if (overlay.hasAttribute("hidden") || !baseWidth || !baseHeight) return;
          event.preventDefault();

          const delta = event.deltaY < 0 ? 0.22 : -0.22;
          const nextScale = Math.min(5, Math.max(1, Number((imageScale + delta).toFixed(2))));
          setScaleAroundPoint(nextScale, event.clientX, event.clientY);
        },
        { passive: false }
      );

      stage.addEventListener("pointerdown", (event) => {
        if (overlay.hasAttribute("hidden") || imageScale <= 1) return;
        if (event.button !== 0) return;

        activePointerId = event.pointerId;
        dragStartX = event.clientX;
        dragStartY = event.clientY;
        dragOriginX = offsetX;
        dragOriginY = offsetY;
        stage.classList.add("is-dragging");
        stage.setPointerCapture(event.pointerId);
        event.preventDefault();
      });

      stage.addEventListener("pointermove", (event) => {
        if (activePointerId !== event.pointerId) return;

        offsetX = dragOriginX + (event.clientX - dragStartX);
        offsetY = dragOriginY + (event.clientY - dragStartY);
        applyTransform();
      });

      stage.addEventListener("pointerup", (event) => {
        if (activePointerId !== event.pointerId) return;
        stopDragging();
      });

      stage.addEventListener("pointercancel", (event) => {
        if (activePointerId !== event.pointerId) return;
        stopDragging();
      });

      stage.addEventListener("lostpointercapture", () => {
        stopDragging();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !overlay.hasAttribute("hidden")) {
          closeLightbox();
        }
      });

      window.addEventListener("resize", () => {
        if (overlay.hasAttribute("hidden")) return;
        requestAnimationFrame(() => {
          baseWidth = overlayImage.clientWidth;
          baseHeight = overlayImage.clientHeight;
          applyTransform();
        });
      });

      articleBody.addEventListener("click", (event) => {
        const image = event.target instanceof Element ? event.target.closest("img") : null;
        if (!(image instanceof HTMLImageElement) || !articleBody.contains(image)) return;

        const source = image.currentSrc || image.src;
        if (!source) return;

        openLightbox(source, image.alt);
      });

      markZoomableImages();
      document.body.appendChild(overlay);
    })();
  </script>
</Layout>
