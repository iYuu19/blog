---
import { getCollection, getEntry } from "astro:content";
import ArchiveRow from "../../components/ArchiveRow.astro";
import TagPill from "../../components/TagPill.astro";
import Layout from "../../layouts/Layout.astro";
import { slugifySegment } from "../../utils/content";
import { getPageLayouts } from "../../utils/site";

const archivePage =
  (
    await getEntry("site-archive", "archive")
  )?.data ?? {
    pageTitle: "归档",
    pageDescription: "按时间整理 iYuu 的比赛 WP、赛后复盘和专题记录。",
    heroEyebrow: "Archive",
    heroTitle: "归档",
    heroIntro: "这里按时间放所有文章。以后更新比赛 WP、赛后复盘或者专题整理，都会先记到这里。",
    postsLabel: "文章",
    writeupsLabel: "比赛 WP",
    reviewsLabel: "复盘",
    indexTitle: "归档索引",
    indexMeta: "这里会按时间一直往下记。",
    indexBlockLabel: "浏览建议",
    indexBlockText: "想按比赛时间看就从上往下翻；想按技术方向回看，可以去标签页。",
    allPostsHeading: "按时间查看",
    allPostsNote: "从新到旧",
    commonTagsHeading: "常看标签"
  };
const pageLayouts = await getPageLayouts();

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];
const tags = allTags.slice(0, 12);
const wpCount = posts.filter((post) => post.data.category === "比赛 WP").length;
const reviewCount = posts.filter((post) => post.data.category === "赛后复盘").length;
const latest = posts[0];
const latestDate = latest
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    }).format(latest.data.pubDate)
  : "";
const groupedPosts = Object.entries(
  posts.reduce<Record<string, typeof posts>>((acc, post) => {
    const year = String(post.data.pubDate.getFullYear());
    (acc[year] ??= []).push(post);
    return acc;
  }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));

const archiveSectionTitleDefaults = {
  "all-posts": archivePage.allPostsHeading,
  "common-tags": archivePage.commonTagsHeading
};

const archiveSectionNoteDefaults = {
  "all-posts": archivePage.allPostsNote,
  "common-tags": ""
};

const archiveSections = (pageLayouts.archiveSections?.length ? pageLayouts.archiveSections : [])
  .filter((section) => section.enabled)
  .map((section, index) => ({
    ...section,
    title: section.title || archiveSectionTitleDefaults[section.type] || `归档板块 ${index + 1}`,
    note: section.note || archiveSectionNoteDefaults[section.type] || "",
    id: slugifySegment(section.anchor || `${section.type}-${index + 1}`)
  }));
---

<Layout title={`${archivePage.pageTitle} | iYuu Notes`} description={archivePage.pageDescription}>
  <section class="shell page-intro">
    <p class="eyebrow">{archivePage.heroEyebrow}</p>
    <h1>{archivePage.heroTitle}</h1>
    <p>{archivePage.heroIntro}</p>
    <p class="meta-line">
      目前一共 {posts.length} 篇。
      {latest && <> 最近一篇是 <a href={`/blog/${latest.slug}/`}>{latest.data.title}</a> · {latestDate}</>}
    </p>
    <dl class="page-stats">
      <div>
        <dt>{archivePage.postsLabel}</dt>
        <dd>{posts.length}</dd>
      </div>
      <div>
        <dt>{archivePage.writeupsLabel}</dt>
        <dd>{wpCount}</dd>
      </div>
      <div>
        <dt>{archivePage.reviewsLabel}</dt>
        <dd>{reviewCount}</dd>
      </div>
    </dl>
  </section>

  <section class="shell archive-page">
    <aside class="index-column">
      <div class="site-index">
        <p class="index-title">{archivePage.indexTitle}</p>
        <ul class="index-list">
          {archiveSections.map((section) => (
            <li><a href={`#${section.id}`}>{section.title}</a></li>
          ))}
          <li><a href="/about">关于这个站</a></li>
        </ul>
        <p class="index-meta">{archivePage.indexMeta}</p>
        <div class="index-block">
          <p class="index-label">{archivePage.indexBlockLabel}</p>
          <p class="index-text">{archivePage.indexBlockText}</p>
        </div>
      </div>
    </aside>

    <div class="archive-main">
      {archiveSections.map((section) => (
        <>
          {
            section.type === "all-posts" && (
              <section class="section" id={section.id}>
                <div class="section-head">
                  <h2>{section.title}</h2>
                  <span class="section-note">{section.note}</span>
                </div>
                <div class="year-stack">
                  {groupedPosts.map(([year, items]) => (
                    <section class="archive-year-group">
                      <p class="archive-year">{year}</p>
                      <div class="archive-list">
                        {items.map((post) => <ArchiveRow post={post} />)}
                      </div>
                    </section>
                  ))}
                </div>
              </section>
            )
          }

          {
            section.type === "common-tags" && (
              <section class="section" id={section.id}>
                <div class="section-head">
                  <h2>{section.title}</h2>
                  {section.note && <span class="section-note">{section.note}</span>}
                </div>
                <div class="tag-cloud">
                  {tags.map((tag) => <TagPill label={tag} href={`/tags/${tag}/`} />)}
                </div>
              </section>
            )
          }
        </>
      ))}
    </div>
  </section>
</Layout>
